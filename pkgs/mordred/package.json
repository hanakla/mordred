{
  "name": "@fleur/mordred",
  "version": "2.0.1",
  "description": "Perfect React Modal library",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "jsdelivr": "dist/index.umd.min.js",
  "unpkg": "dist/index.umd.min.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/hanakla/mordred",
    "directory": "pkgs/mordred"
  },
  "author": "Hanakla <hanakla.dev@gmail.com>",
  "license": "MIT",
  "scripts": {
    "clean-dist": "rm -rf ./dist",
    "build:declarations": "tsc --emitDeclarationOnly --declaration --outDir ./dist",
    "build:esm": "bili",
    "build": "yarn build:declarations && yarn build:esm",
    "start": "bili -w",
    "prepublishOnly": "yarn clean-dist && yarn build"
  },
  "devDependencies": {
    "@types/domready": "^1.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "bili": "^5.0.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rollup": "^4.18.1",
    "rollup-plugin-typescript2": "^0.36.0",
    "typescript": "^4.1.3"
  },
  "peerDependencies": {
    "react": "^17||^18||^19",
    "react-dom": "^17||^18||^19"
  },
  "dependencies": {
    "focus-trap": "^6.2.3"
  }
}
